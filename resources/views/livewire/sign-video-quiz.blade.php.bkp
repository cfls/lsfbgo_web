        <!-- CONTENIDO PRINCIPAL ANIMADO -->
        <div class="bg-gray-300 p-5">
            @if($currentQuestion)
                <div
                        x-transition:enter="transform transition ease-out duration-700"
                        x-transition:enter-start="translate-x-20 opacity-0 scale-95"
                        x-transition:enter-end="translate-x-0 opacity-100 scale-100"
                        x-transition:leave="transform transition ease-in duration-500"
                        x-transition:enter-start="-translate-x-20 opacity-0 scale-95"
                        x-transition:leave-end="translate-x-20 opacity-0 scale-95"
                        :class="{ 'translate-x-full opacity-0': slideOut }"
                >

                    <div class="flex justify-center mx-auto mb-5 font-medium text-sm bg-blue-950 p-5 text-white rounded-lg  text-center">
                        Question {{ $currentIndex + 1 }} à {{ $this->totalQuestions }}
                    </div>
                    <h2 class="font-medium text-sm mb-4 text-center text-black">{{$currentQuestion['question_text']}}</h2>

                    {{-- === VIDEO PRINCIPAL === --}}
                    <div
                            x-show="!slideOut"
                            x-transition:enter="transition-all ease-out duration-500"
                            x-transition:enter-start="opacity-0 translate-y-3"
                            x-transition:enter-end="opacity-100 translate-y-0"
                            x-transition:leave="transition-all ease-in duration-300"
                            x-transition:leave-start="opacity-100 translate-y-0"
                            x-transition:leave-end="opacity-0 translate-y-3"
                            wire:key="video-main-{{ $currentIndex }}"
                    >
                        <x-sign-video-main
                                :video="$currentQuestion['video']"
                                :type="$currentQuestion['type']"
                        />
                    </div>

                    {{-- === CHOICE === --}}
                    @if($currentQuestion['type'] === 'choice')
                        <x-sign-video-validate-button
                                :options="$currentQuestion['options']"
                                :selectedAnswer="$selectedAnswer"
                                :answered="$answered"
                        />
                    @endif


                    {{-- === TEXT === --}}
                    @if($currentQuestion['type'] === 'text')
                        <div class="flex justify-center mt-4">
                            <input type="text"
                                   wire:model.live="userInput"
                                   class="border rounded px-3 py-2 text-center bg-white w-1/2 text-black"
                                   placeholder="Votre réponse" />
                        </div>
                    @endif


                    {{-- === MATCH === --}}
                    @if($currentQuestion['type'] === 'match')
                        @php

                            $pairs = is_string($currentQuestion['options'])
                                ? json_decode($currentQuestion['options'], true)
                                : $currentQuestion['options'];
                        @endphp

                        @livewire('sign-video-match', [
                            'pairs' => $pairs,
                        ], key('sign-video-match-'.$currentIndex))
                    @endif


                    {{-- === VIDEO CHOICE === --}}
                    @if($currentQuestion['type'] === 'video-choice')
                        <div
                                x-show="!slideOut"
                                x-transition:enter="transition-all ease-out duration-500"
                                x-transition:enter-start="opacity-0 translate-y-3"
                                x-transition:enter-end="opacity-100 translate-y-0"
                                x-transition:leave="transition-all ease-in duration-300"
                                x-transition:leave-start="opacity-100 translate-y-0"
                                x-transition:leave-end="opacity-0 translate-y-3"
                                wire:key="video-main-{{ $currentIndex }}"
                        >
                            <x-sign-video-options
                                    :options="$currentQuestion['options']"
                                    :correct="$currentQuestion['answer']"
                                    :selected="$selectedAnswer"
                                    :answered="$answered"
                            />
                        </div>
                    @endif

                    {{-- === YES/NO === --}}
                    @if($currentQuestion['type'] === 'yes-no')
                        <div class="flex gap-4 justify-center mt-4">
                            <button type="button"
                                    class="px-5 py-2 rounded-lg border
                    {{ $answered ? 'pointer-events-none opacity-70' : '' }}
                    {{ $selectedAnswer === 'oui'
                        ? 'bg-blue-600 text-white'
                        : 'bg-white text-black' }}"
                                    wire:click="selectAnswer('oui')">
                                Oui
                            </button>
                            <button type="button"
                                    class="px-5 py-2 rounded-lg border
                    {{ $answered ? 'pointer-events-none opacity-70' : '' }}
                    {{ $selectedAnswer === 'non'
                        ? 'bg-blue-600 text-white'
                        : 'bg-white text-black' }}"
                                    wire:click="selectAnswer('non')">
                                Non
                            </button>
                        </div>
                    @endif

                    {{-- === BOTÓN VALIDAR === --}}
                    @if(!$answered && $currentQuestion['type'] !== 'video-choice' && $currentQuestion['type'] !== 'match')
                        <div class="flex justify-center mt-4">
                            <flux:button
                                    variant="primary"
                                    color="sky"
                                    class="w-32 cursor-pointer {{ $answered || (!$selectedAnswer && empty($userInput)) ? 'opacity-50 cursor-not-allowed pointer-events-none' : '' }}"
                                    wire:click="checkAnswer"
                            >
                                Valider
                            </flux:button>
                        </div>
                    @endif
                    {{-- === BOTÓN SUIVANT === --}}
                    @if ($currentQuestion['type'] !== 'match' && $answered)
                        <x-sign-video-next-button :nextStep="'nextQuestion'" />
                    @endif

                    @if ($answered && $currentQuestion['type'] === 'match')
                        @if (!$isCorrect)
                            <div class="mt-4 text-center text-green-600 font-bold">
                                <x-sign-video-next-button :nextStep="'nextQuestion'" />
                            </div>
                        @else
                            <div class="mt-4 text-center text-green-600 font-bold">
                                <x-sign-video-next-button :nextStep="'nextQuestion'" />
                            </div>
                        @endif
                    @endif

                    {{-- === MENSAJE === --}}
                    <x-sign-video-feedback
                            :isCorrect="$isCorrect"
                            :message="$message"
                            :image="$image"
                            :currentQuestion="$currentQuestion"
                    />


                </div>
            @else
                <div class="flex justify-center">Aucun thème disponible</div>
            @endif
        </div>
    </div>

</div>

@push('scripts-video-quiz')
    <script>
        /* ====== util ====== */
        (function(){
            // Debounce simple
            function debounce(fn, wait){ let t; return (...a)=>{ clearTimeout(t); t=setTimeout(()=>fn.apply(null,a), wait); }; }

            // Exponer en window
            window.cloudPlayers = [];
            window.initPlayers = function(){


                // Destruir anteriores
                try { window.cloudPlayers.forEach(p => { try { p.destroy(); } catch(e){} }); } catch(e){}
                window.cloudPlayers = [];

                // Validar Cloudinary
                if (typeof cloudinary === "undefined" || !cloudinary.videoPlayer) {
                    console.warn("⚠️ Cloudinary player no disponible aún");
                    return;
                }

                // Player principal
                const mainEl = document.getElementById("main-video");
                if (mainEl) {
                    const pid = (mainEl.dataset.publicId || "");
                    if (pid) {
                        const p = cloudinary.videoPlayer("main-video", {
                            cloud_name: "dmhdsjmzf",
                            autoplayMode: "always",
                            controls: false,
                            muted: true,
                            loop: true,
                            fluid: true
                        });
                        p.source(pid);
                        window.cloudPlayers.push(p);
                    }
                }

                // Players de opciones
                document.querySelectorAll('video.cld-option').forEach(el => {
                    const pid = el.dataset.publicId;
                    if (!pid || !el.id) return;

                    const player = cloudinary.videoPlayer(el.id, {
                        cloud_name: "dmhdsjmzf",
                        autoplayMode: "always",
                        controls: false,
                        muted: true,
                        loop: true,
                        fluid: true
                    });

                    player.source(pid);
                    window.cloudPlayers.push(player);
                });
            };

            const safeInit = debounce(()=>window.initPlayers(), 200);

            // 1) Primera carga DOM
            document.addEventListener("DOMContentLoaded", safeInit);

            // 2) Livewire (v2/v3): re-render completado
            // v3:
            document.addEventListener("livewire:initialized", () => {
                try {
                    Livewire.hook("message.processed", () => { safeInit(); });
                } catch(e) {}
            });
            // v2 (por compat):
            document.addEventListener("livewire:load", () => {
                try {
                    Livewire.hook("message.processed", () => { safeInit(); });
                } catch(e) {}
            });

            // 3) Tus eventos personalizados (por si los sigues emitiendo)
            window.addEventListener("quiz-video-update", safeInit);
            window.addEventListener("quiz-video-refresh", safeInit);
            window.addEventListener("next-step", safeInit);

            // 4) Observador de cambios de DOM (última red)
            // Observa el contenedor principal del quiz
            const root = document.querySelector("#videochoice") || document.body;
            if (root && "MutationObserver" in window) {
                const mo = new MutationObserver(safeInit);
                mo.observe(root, { childList:true, subtree:true });
            }
        })();
    </script>

@endpush