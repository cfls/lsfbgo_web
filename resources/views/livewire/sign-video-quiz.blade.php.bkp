    <div class="rounded-xl w-full mx-auto"
         x-data="{
        slow: false,
        toggleSpeed() {
            this.slow = !this.slow;
            document.querySelectorAll('video').forEach(v => v.playbackRate = this.slow ? 0.5 : 1);
        },

        openCongrats: false,
        showFailModal: false,
        score: 0,
        openSubscription: false,

        slideOut: false
    }"

         @quiz-failed.window="
        openCongrats = false;
        showFailModal = true;
        score = $event.detail.percentage;
    "
         @quiz-finished.window="
        showFailModal = false;
        openCongrats = true;
    "
         @subscription-required.window="openSubscription = true"
         @next-step.window="
            slideOut = true;
            setTimeout(() => {
                slideOut = false;
            }, 650);
        "
    >


        <!-- Modal de Félicitations -->
        <div
                class="fixed inset-0 flex items-center justify-center bg-black/60 z-50"
                x-show="openCongrats && !showFailModal"
                x-transition
