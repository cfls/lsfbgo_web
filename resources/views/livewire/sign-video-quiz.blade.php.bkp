    @php
        use Illuminate\Support\Str;

        // prend uniquement la première partie avant le "-"
        $ue = Str::before($slug, '-');

        // met en majuscules "ue1" => "UE 1"
        $ue = strtoupper(Str::replace('ue', 'UE ', $ue));


